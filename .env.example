# =============================================================================
# Doclify — root .env.example
# =============================================================================
# Lido por Astro (5.x) via `loadEnv` em `astro.config.mjs`. A presença de
# `PUBLIC_API_URL` é obrigatória — o build falha sem ela (mensagem em PT-BR).
#
# Copie para `.env` na raiz do projeto e ajuste o valor:
#   cp .env.example .env                 (Linux/macOS)
#   copy .env.example .env               (Windows)
# =============================================================================

# --- Frontend → API -----------------------------------------------------------
# Onde o frontend (no browser) acha o backend PHP.
#
# Dev com XAMPP Apache em :80 servindo `htdocs/`:
PUBLIC_API_URL=http://localhost/api

# Dev com servidor PHP built-in em :8080 + Astro dev em :4321:
# PUBLIC_API_URL=http://127.0.0.1:8080/api

# Produção (substitua pelo domínio definitivo):
# PUBLIC_API_URL=https://api.doclify.com
