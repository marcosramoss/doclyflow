---
// =============================================================================
// Doclyflow — seção "Telas do sistema" da landingpage
// =============================================================================
// 4 mockups reais (Dashboard, Criar documento, Requisitos, PDF gerado) usados
// na landing como prova visual do produto, cada um acompanhado de um texto
// ao lado descrevendo o processo e a experiência de uso.
//
// Layout: zigzag side-by-side. Em telas >= lg, o texto fica à esquerda nas
// linhas pares e à direita nas linhas ímpares (visualmente alternado para
// criar ritmo). Em mobile, empilha verticalmente (texto → tela, em ordem).
//
// Animação: o mesmo padrão de reveal-on-scroll usado em FeaturesGrid e
// StepsTimeline — `data-screens-root` recebe `.is-visible` via
// IntersectionObserver, e a regra CSS usa `--screen-index` (definido inline
// em cada `.screens-row`) para calcular o `transition-delay` (stagger de
// 100ms entre as 4 linhas). Fallbacks: `prefers-reduced-motion` e
// `<noscript>` mostram o estado final imediatamente.
// =============================================================================

import { Sparkles, Check } from "lucide-react";
import ScreenCard from "./ScreenCard.astro";
import DashboardScreen from "./screens/DashboardScreen.astro";
import DocumentFormScreen from "./screens/DocumentFormScreen.astro";
import RequirementsScreen from "./screens/RequirementsScreen.astro";
import PdfScreen from "./screens/PdfScreen.astro";

// Tipo do `Component` inferido automaticamente pelo TS a partir do array
// literal (união de `typeof DashboardScreen | ...`). Sem necessidade de
// declarar um `ScreenDef` à mão.
//
// Cada item também carrega `features`: 3-4 bullets com check que aparecem
// abaixo do `body` para preencher o vão vertical deixado pelo mockup
// (sempre mais alto que o texto) sem competir visualmente com ele.
//
// IMPORTANTE: as `features` DEVEM corresponder a comportamento JÁ
// implementado no produto. Manter em sincronia com o código real:
//
//   - Card 01 (lista)         → `src/react/DashboardTable.tsx`
//   - Card 02 (criar)         → `src/react/RequirementsForm.tsx`
//                                + `src/data/templates.ts`
//   - Card 03 (visualização)  → `src/react/DocumentView.tsx`
//   - Card 04 (PDF)           → `src/utils/pdfGenerator.ts`
//
// Adicionar feature aspiracional aqui quebra expectativa do usuário —
// só entre no array depois de implementado no código do produto.
// O array `pillLabels` segue a mesma regra: rótulos que aparecem no UI
// real de cada tela (status tabs no dashboard, sections do form,
// StatCards da visualização, blocos da página PDF).
const SCREENS = [
  {
    label: "Dashboard — lista de documentos",
    dotColor: "bg-brand-500",
    stepNumber: "01",
    headline: "Tudo o que você já criou, em uma tela.",
    body: "Filtre por cliente, status ou texto. Abra o documento que precisa em um clique — sem perder tempo em pastas ou no histórico do navegador.",
    features: [
      "Busca por título, cliente ou texto",
      "Filtros por status com contadores",
      "Salvos na nuvem automaticamente",
      "Atualização ao mudar de aba",
    ],
    // Textos das pills = labels das status tabs reais no topo do
    // dashboard (`STATUS_LABEL` em DashboardTable.tsx).
    pillLabels: ["Rascunho", "Em andamento", "Concluído"],
    Component: DashboardScreen,
  },
  {
    label: "Criar documento",
    dotColor: "bg-violet-500",
    stepNumber: "02",
    headline: "Do template ao rascunho em menos de um minuto.",
    body: "Título, cliente, descrição e requisitos — organizados em blocos para você não esquecer nenhum campo. Comece de um template ou do zero.",
    features: [
      "4 templates prontos para começar",
      "Validação completa antes de salvar",
      "Salvar como rascunho quando quiser",
      "Stack em chips selecionáveis",
    ],
    // Textos das pills = cabeçalhos reais das 3 sections do formulário
    // (`Dados do projeto` / `Requisitos` / `Tecnologias` em
    // RequirementsForm.tsx). Só `Dados` é genuinamente encurtado
    // (de "Dados do projeto"); `Requisitos` e `Tecnologias` entram
    // verbatim e cabem no pill por já serem curtos.
    pillLabels: ["Dados", "Requisitos", "Tecnologias"],
    Component: DocumentFormScreen,
  },
  {
    label: "Visualização dos requisitos",
    dotColor: "bg-amber-500",
    stepNumber: "03",
    headline: "Visão geral sem perder o detalhe.",
    body: "Cada requisito tem tipo, prioridade e descrição. Edite, reordene ou marque como concluído direto na lista — sem abrir cinco telas diferentes.",
    features: [
      "Numeração sequencial automática",
      "Contadores de totais no topo",
      "Grupos separados por tipo",
      "Cores por prioridade com badges",
    ],
    // Textos das pills = 3 dos 4 StatCards no topo da visualização
    // (`DocumentView.tsx` → componente StatCard com accents brand/blue/
    // violet/red). `Não-funcionais` omitido por restrição de 3 colunas.
    pillLabels: ["Total", "Funcionais", "Críticos"],
    Component: RequirementsScreen,
  },
  {
    label: "PDF gerado pronto para enviar",
    dotColor: "bg-emerald-500",
    stepNumber: "04",
    headline: "Um clique. Pronto pro cliente.",
    body: "PDF formatado com capa, índice e paginação. Baixe, anexe em e-mail ou imprima — sai com a cara de um documento feito por uma consultoria cara.",
    features: [
      "Capa com projeto + cliente",
      "Resumo com totais por tipo",
      "Multi-página com quebra automática",
      "Cores por tipo e prioridade",
    ],
    // Textos das pills = 3 partes estruturais da página PDF gerada
    // (`pdfGenerator.ts`) — header (capa em brand), seção RESUMO com
    // totais, e footer per-page com paginação.
    pillLabels: ["Capa", "Resumo", "Rodapé"],
    Component: PdfScreen,
  },
];
---

<section
  class="relative overflow-hidden border-t border-slate-200 bg-slate-50 py-24"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span
        class="inline-flex items-center gap-1.5 rounded-full border border-brand-200 bg-white/80 px-3 py-1 text-xs font-semibold text-brand-700 shadow-sm backdrop-blur"
      >
        <Sparkles size={12} /> Por dentro
      </span>
      <h2
        class="mt-5 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
      >
        Veja o sistema por dentro
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Conheça o seu novo gestor de levantamentos de requisitos.
      </p>
    </div>

    <div data-screens-root class="mt-20 space-y-24 lg:space-y-32">
      {
        SCREENS.map((s, i) => (
          <div
            class:list={[
              // Mobile: coluna simples — `items-center` em flex-col faria os
              // filhos encolherem à largura intrínseca do conteúdo, e o mockup
              // (com seu grid de stats/tabs) acabava vazando horizontalmente no
              // viewport estreito do Mi 11 5G (~393px). Mantemos o stretch
              // padrão no mobile.
              // No desktop (lg), alinhamos ao topo (`lg:items-start`) para que
              // o texto siga o mockup em ritmo de leitura. O vão vertical é
              // preenchido pela lista de recursos renderizada em
              // `.screens-row__text` (ver `s.features`).
              "screens-row flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-16",
              // Zigzag: linhas ímpares invertem a ordem visual (screen à
              // esquerda, texto à direita). `flex-row-reverse` preserva a
              // ordem do markup (texto → screen) para mobile.
              i % 2 === 1 && "lg:flex-row-reverse",
            ]}
            style={`--screen-index:${i}`}
          >
            <div class="screens-row__text w-full min-w-0 flex-1">
              <div class="flex items-center gap-3">
                <span class={`h-2 w-2 rounded-full ${s.dotColor}`} />
                <span class="font-mono text-xs font-semibold tracking-widest text-slate-400">
                  {s.stepNumber}
                </span>
              </div>
              <h3 class="mt-5 text-2xl font-bold leading-tight tracking-tight text-slate-900 sm:text-3xl">
                {s.headline}
              </h3>
              <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
                {s.body}
              </p>
              {/* Lista de recursos complementares — preenche o vão vertical
                  deixado pelo mockup (sempre mais alto que o texto) e reforça
                  visualmente os benefícios sem repetir a copy do `body`. */}
              <ul class="mt-8 space-y-2.5 rounded-lg border border-slate-200 bg-white p-3">
                {
                  s.features.map((f) => (
                    <li class="flex items-start gap-2 text-sm text-slate-700">
                      {/* size 16 + strokeWidth 2.5: mais peso visual que o
                          default (size 14 + stroke 2) sem virar ilustração.
                          Compensa o fato de o mobile ter DPR alto (~2.75 no
                          Mi 11 5G), onde traits finos somem. */}
                      <Check
                        size={16}
                        strokeWidth={2.5}
                        className="mt-0.5 shrink-0 text-emerald-600"
                      />
                      <span>{f}</span>
                    </li>
                  ))
                }
              </ul>
              {/* Decoração desktop-only: bloco puramente visual (`aria-hidden`
                  true) que preenche o vão vertical entre a lista de recursos
                  e a altura do mockup sem adicionar conteúdo novo (zero
                  risco de prometer feature inexistente). `hidden lg:block`
                  esconde em mobile — o stack empilhado (texto → features)
                  já preenche a coluna naturalmente.

                  Timeline numerada (01 → 04 conectados por linha fina):
                  remete diretamente à estrutura da própria seção
                  ("Telas do sistema" tem 4 cards de tela em zigzag).
                  h-32 (128px) fixo garante que nunca excede a menor das
                  4 telas (~440px PdfScreen A4).

                  Sem tile emoldurado — foi o que desagradou na versão
                  anterior. Aqui os 4 nós ficam livres sobre o
                  `bg-slate-50/60`, leitura limpa e simétrica. */}
              <div
                class="hidden lg:block mt-8 h-32 overflow-hidden rounded-2xl bg-slate-50/60"
                aria-hidden="true"
              >
                {/* 3 pills em row, conectadas por linhas finas slate-400
                    (não slate-300) → contraste mínimo sobre bg-slate-50/60
                    da outer. `h-0.5` (não h-px) no conector → evita render
                    subpixel em HiDPI (Mi 11 5G DPR ~2.75, retina em geral).

                    Tipografia + borda + padding EXATAMENTE iguais aos badges
                    reais renderizados no DashboardTable.tsx via
                    `inline-flex items-center gap-1 rounded-full
                     px-2.5 py-0.5 text-[11px] font-semibold ring-1
                     ${STATUS_STYLES[d.status]}` — fidelidade reconhecida,
                    não estilização genérica.

                    Cores (slate/blue/emerald) ficam FIXAS em todos os cards
                    (carregam a hierarquia visual "base → ativo → pronto"
                    consistente com a STATUS_STYLES do produto). Os TEXTOS
                    mudam por card via `s.pillLabels`, referenciando
                    elementos visíveis na tela correspondente. */}
                {/* Pills alinhados a esquerda como o resto do conteudo do
                    card (step indicator, headline, body, features list).
                    Sem `absolute inset-0 flex justify-center` da versao
                    anterior — agora pills fluem no canto superior-esquerdo
                    do retangulo slate-50/60, em sequencia natural apos a
                    lista de features acima. `pt-4 px-4` dá respiro do topo + laterais (sem folga inútil embaixo). */}
                <div class="flex items-center gap-3 pt-4 px-4">
                  {[
                    { bg: "bg-slate-100", text: "text-slate-700",   ring: "ring-slate-200" },
                    { bg: "bg-blue-100", text: "text-blue-700",     ring: "ring-blue-200" },
                    { bg: "bg-emerald-100", text: "text-emerald-700", ring: "ring-emerald-200" },
                  ].map((style, idx, arr) => (
                    <>
                      <span class={`inline-flex items-center gap-1 rounded-full ${style.bg} px-2.5 py-0.5 text-[11px] font-semibold ${style.text} ring-1 ${style.ring}`}>{s.pillLabels[idx] ?? ""}</span>
                      {idx !== arr.length - 1 && (
                        <span class="h-0.5 w-8 bg-slate-400"></span>
                      )}
                    </>
                  ))}
                </div>
              </div>
            </div>
            <div class="w-full min-w-0 flex-1">
              <ScreenCard label={s.label} dotColor={s.dotColor}>
                <s.Component />
              </ScreenCard>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  /* Animação no nível da LINHA (não do card). Cada `.screens-row` carrega
   * seu próprio `--screen-index` inline, então o stagger de 100ms acontece
   * entre as 4 linhas, não entre os sub-elementos. */
  [data-screens-root] .screens-row {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 480ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 480ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Usuários com `prefers-reduced-motion` veem o estado final
   * imediatamente, sem transição. */
  @media (prefers-reduced-motion: reduce) {
    [data-screens-root] .screens-row {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  /* Dispara o reveal quando o IntersectionObserver adiciona `.is-visible`
   * ao `[data-screens-root]`. Stagger 100ms por linha via `--screen-index`
   * definido inline. */
  [data-screens-root].is-visible .screens-row {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--screen-index, 0) * 100ms);
  }
</style>

<!--
  No-JS fallback. Inline styles bypassam o bloco global de <style>
  (que esconde o conteúdo por padrão) para que usuários sem JS ainda
  vejam a seção no estado final.
-->
<noscript>
  <style>
    [data-screens-root] .screens-row {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<script>
  // Reveal uma vez só — disconnect após o primeiro hit para a animação
  // não voltar quando o usuário rolar pra cima e pra baixo.
  const roots = document.querySelectorAll<HTMLElement>(
    "[data-screens-root]",
  );
  for (const root of roots) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: "0px 0px -60px 0px" },
    );
    io.observe(root);
  }
</script>
