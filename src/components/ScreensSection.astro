---
// =============================================================================
// Doclyflow — seção "Telas do sistema" da landingpage
// =============================================================================
// 4 mockups reais (Dashboard, Criar documento, Requisitos, PDF gerado) usados
// na landing como prova visual do produto, cada um acompanhado de um texto
// ao lado descrevendo o processo e a experiência de uso.
//
// Layout: zigzag side-by-side. Em telas >= lg, o texto fica à esquerda nas
// linhas pares e à direita nas linhas ímpares (visualmente alternado para
// criar ritmo). Em mobile, empilha verticalmente (texto → tela, em ordem).
//
// Animação: o mesmo padrão de reveal-on-scroll usado em FeaturesGrid e
// StepsTimeline — `data-screens-root` recebe `.is-visible` via
// IntersectionObserver, e a regra CSS usa `--screen-index` (definido inline
// em cada `.screens-row`) para calcular o `transition-delay` (stagger de
// 100ms entre as 4 linhas). Fallbacks: `prefers-reduced-motion` e
// `<noscript>` mostram o estado final imediatamente.
// =============================================================================

import { Sparkles } from "lucide-react";
import ScreenCard from "./ScreenCard.astro";
import DashboardScreen from "./screens/DashboardScreen.astro";
import DocumentFormScreen from "./screens/DocumentFormScreen.astro";
import RequirementsScreen from "./screens/RequirementsScreen.astro";
import PdfScreen from "./screens/PdfScreen.astro";

// Tipo do `Component` inferido automaticamente pelo TS a partir do array
// literal (união de `typeof DashboardScreen | ...`). Sem necessidade de
// declarar um `ScreenDef` à mão.
const SCREENS = [
  {
    label: "Dashboard — lista de documentos",
    dotColor: "bg-brand-500",
    stepNumber: "01",
    headline: "Tudo o que você já criou, em uma tela.",
    body: "Filtre por cliente, status ou texto. Abra o documento que precisa em um clique — sem perder tempo em pastas ou no histórico do navegador.",
    Component: DashboardScreen,
  },
  {
    label: "Criar documento",
    dotColor: "bg-violet-500",
    stepNumber: "02",
    headline: "Do template ao rascunho em menos de um minuto.",
    body: "Título, cliente, descrição e requisitos — organizados em blocos para você não esquecer nenhum campo. Comece de um template ou do zero.",
    Component: DocumentFormScreen,
  },
  {
    label: "Visualização dos requisitos",
    dotColor: "bg-amber-500",
    stepNumber: "03",
    headline: "Visão geral sem perder o detalhe.",
    body: "Cada requisito tem tipo, prioridade e descrição. Edite, reordene ou marque como concluído direto na lista — sem abrir cinco telas diferentes.",
    Component: RequirementsScreen,
  },
  {
    label: "PDF gerado pronto para enviar",
    dotColor: "bg-emerald-500",
    stepNumber: "04",
    headline: "Um clique. Pronto pro cliente.",
    body: "PDF formatado com capa, índice e paginação. Baixe, anexe em e-mail ou imprima — sai com a cara de um documento feito por uma consultoria cara.",
    Component: PdfScreen,
  },
];
---

<section
  class="relative overflow-hidden border-t border-slate-200 bg-slate-50 py-24"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span
        class="inline-flex items-center gap-1.5 rounded-full border border-brand-200 bg-white/80 px-3 py-1 text-xs font-semibold text-brand-700 shadow-sm backdrop-blur"
      >
        <Sparkles size={12} /> Por dentro
      </span>
      <h2
        class="mt-5 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
      >
        Veja o sistema por dentro
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Conheça o seu novo gestor de levantamentos de requisitos.
      </p>
    </div>

    <div data-screens-root class="mt-20 space-y-24 lg:space-y-32">
      {
        SCREENS.map((s, i) => (
          <div
            class:list={[
              "screens-row flex flex-col items-center gap-10 lg:flex-row lg:gap-16",
              // Zigzag: linhas ímpares invertem a ordem visual (screen à
              // esquerda, texto à direita). `flex-row-reverse` preserva a
              // ordem do markup (texto → screen) para mobile.
              i % 2 === 1 && "lg:flex-row-reverse",
            ]}
            style={`--screen-index:${i}`}
          >
            <div class="screens-row__text flex-1">
              <div class="flex items-center gap-3">
                <span class={`h-2 w-2 rounded-full ${s.dotColor}`} />
                <span class="font-mono text-xs font-semibold tracking-widest text-slate-400">
                  {s.stepNumber}
                </span>
              </div>
              <h3 class="mt-5 text-2xl font-bold leading-tight tracking-tight text-slate-900 sm:text-3xl">
                {s.headline}
              </h3>
              <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
                {s.body}
              </p>
            </div>
            <div class="flex-1">
              <ScreenCard label={s.label} dotColor={s.dotColor}>
                <s.Component />
              </ScreenCard>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  /* Animação no nível da LINHA (não do card). Cada `.screens-row` carrega
   * seu próprio `--screen-index` inline, então o stagger de 100ms acontece
   * entre as 4 linhas, não entre os sub-elementos. */
  [data-screens-root] .screens-row {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 480ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 480ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Usuários com `prefers-reduced-motion` veem o estado final
   * imediatamente, sem transição. */
  @media (prefers-reduced-motion: reduce) {
    [data-screens-root] .screens-row {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  /* Dispara o reveal quando o IntersectionObserver adiciona `.is-visible`
   * ao `[data-screens-root]`. Stagger 100ms por linha via `--screen-index`
   * definido inline. */
  [data-screens-root].is-visible .screens-row {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--screen-index, 0) * 100ms);
  }
</style>

<!--
  No-JS fallback. Inline styles bypassam o bloco global de <style>
  (que esconde o conteúdo por padrão) para que usuários sem JS ainda
  vejam a seção no estado final.
-->
<noscript>
  <style>
    [data-screens-root] .screens-row {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<script>
  // Reveal uma vez só — disconnect após o primeiro hit para a animação
  // não voltar quando o usuário rolar pra cima e pra baixo.
  const roots = document.querySelectorAll<HTMLElement>(
    "[data-screens-root]",
  );
  for (const root of roots) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: "0px 0px -60px 0px" },
    );
    io.observe(root);
  }
</script>
