---
import HeaderUserMenu from "../react/HeaderUserMenu.tsx";
import logoDark from "../../public/logo-dark-doclify.svg";
---

<header
  class="sticky top-0 z-40 border-b border-slate-200/80 bg-white backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <a
      href="/"
      class="group flex items-center gap-3 transition-opacity hover:opacity-80"
    >
      <img src={logoDark.src} alt="" />
      <span class="text-lg font-bold tracking-tight text-slate-900"> </span>
    </a>

    <HeaderUserMenu client:load />
  </div>
</header>
