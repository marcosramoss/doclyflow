---
import HeaderUserMenu from "../react/HeaderUserMenu.tsx";
import GitHubStarsBadge from "./GitHubStarsBadge.astro";
import logoDark from "../../public/logo-dark-doclyflow.svg";
---

<header
  class="sticky top-0 z-40 border-b border-slate-200/80 bg-white backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <a
      href="/"
      class="group flex items-center gap-3 transition-opacity hover:opacity-80"
    >
      <img class="max-sm:w-44" src={logoDark.src} alt="" />
      <span class="text-lg font-bold tracking-tight text-slate-900"> </span>
    </a>

    <div class="flex items-center gap-4">
      <GitHubStarsBadge />
      <!-- HeaderUserMenu fica oculto no modo open-source (login acontece no
           hero da landing: "Comece agora" + "Entrar com Google"). Remover o
           `class="hidden"` no wrapper restaura o botão Entrar / avatar+Sair. -->
      <div class="hidden">
        <HeaderUserMenu client:load />
      </div>
    </div>
  </div>
</header>
