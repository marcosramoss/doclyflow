---
import Layout from '../../layouts/Layout.astro';
import RequirementsForm from '../../react/RequirementsForm.tsx';
import AppSidebar from '../../react/AppSidebar.tsx';

const editId = Astro.url.searchParams.get('id') ?? undefined;
const isEdit = Boolean(editId);
---

<Layout
  title={isEdit ? 'Editar Documento · RequisitaApp' : 'Novo Documento · RequisitaApp'}
>
  <div class="mx-auto grid max-w-7xl items-start gap-6 px-4 py-8 sm:px-6 sm:py-10 lg:grid-cols-[260px_1fr]">
    <AppSidebar client:only="react" activeRoute="new" />
    <main class="min-w-0">
      <RequirementsForm client:load documentId={editId} />
    </main>
  </div>
</Layout>
