---
import Layout from '../../layouts/Layout.astro';
import DashboardTable from '../../react/DashboardTable.tsx';
import AppSidebar from '../../react/AppSidebar.tsx';
---

<Layout title="Documentos · Doclify">
  <div class="mx-auto grid max-w-7xl items-start gap-6 px-4 py-8 sm:px-6 sm:py-10 lg:grid-cols-[260px_1fr]">
    <AppSidebar client:only="react" activeRoute="documents" />
    <main class="min-w-0">
      <DashboardTable client:load />
    </main>
  </div>
</Layout>
