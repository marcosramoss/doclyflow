---
import Layout from '../layouts/Layout.astro';
import LoginForm from '../react/LoginForm.tsx';
---

<Layout
  title="Entrar — Doclyflow · Login com Google"
  description="Entre no Doclyflow com sua conta Google e acesse seus documentos de levantamento de requisitos salvos na nuvem."
>
  <section class="mx-auto flex min-h-[calc(100vh-12rem)] max-w-7xl items-center justify-center px-6 py-10">
    <LoginForm client:load />
  </section>
</Layout>
