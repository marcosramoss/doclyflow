---
import Layout from "../layouts/Layout.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import FeaturesGrid from "../components/FeaturesGrid.astro";
import ScreenCard from "../components/ScreenCard.astro";
import DashboardScreen from "../components/screens/DashboardScreen.astro";
import DocumentFormScreen from "../components/screens/DocumentFormScreen.astro";
import RequirementsScreen from "../components/screens/RequirementsScreen.astro";
import PdfScreen from "../components/screens/PdfScreen.astro";
import {
  Sparkles,
  FileText,
  Layers,
  Download,
  Cloudy,
  LogIn,
  CheckCircle2,
  Search,
} from "lucide-react";

const features = [
  {
    icon: FileText,
    title: "Documentos estruturados",
    body: "Modelo padrão com título, cliente, descrição e requisitos funcionais e não-funcionais.",
  },
  {
    icon: Layers,
    title: "Requisitos detalhados",
    body: "Adicione quantos requisitos quiser, defina tipo, prioridade e descrição rica.",
  },
  {
    icon: Download,
    title: "Exporte em PDF ou Markdown",
    body: "PDF profissional pronto para enviar ao cliente, ou .md estruturado para usar como contexto em uma IA.",
  },
  {
    icon: Cloudy,
    title: "Tudo salvo na nuvem",
    body: "Documentos persistidos no servidor e vinculados à sua conta — acesse de qualquer navegador.",
  },
  {
    icon: Search,
    title: "Busca e filtros",
    body: "Encontre rapidamente documentos por título, cliente ou status.",
  },
  {
    icon: LogIn,
    title: "Login com Google",
    body: "Sem senhas extras — entre com sua conta Google e seu workspace já está pronto para usar.",
  },
];

const steps = [
  {
    n: 1,
    t: "Crie um documento",
    d: "Informe título, cliente e descrição do projeto.",
    icon: FileText,
  },
  {
    n: 2,
    t: "Adicione requisitos",
    d: "Liste funcionais e não-funcionais, com prioridade.",
    icon: Layers,
  },
  {
    n: 3,
    t: "Exporte o PDF",
    d: "Baixe um documento profissional em um clique.",
    icon: Download,
  },
];
---

<Layout
  title="Doclyflow — Levante requisitos e exporte em PDF ou Markdown"
  description="Crie, organize e exporte levantamentos de requisitos profissionais em PDF ou Markdown com o Doclyflow. Login com Google, tudo salvo na nuvem — sem cadastro e sem complicação."
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 bg-linear-to-b from-brand-50 via-white to-slate-50"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-32 -right-40 -z-10 h-112 w-md rounded-full bg-brand-200/50 blur-3xl"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -bottom-32 -left-40 -z-10 h-112 w-md rounded-full bg-sky-200/40 blur-3xl"
    >
    </div>

    <div
      class="mx-auto grid max-w-7xl items-center gap-14 px-6 py-20 lg:grid-cols-2 lg:gap-20 lg:py-28"
    >
      <div>
        <span
          class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-white/80 px-3 py-1 text-xs font-semibold text-brand-700 shadow-sm backdrop-blur"
        >
          <Sparkles size={14} />
          Gerador inteligente de requisitos
        </span>
        <h1
          class="mt-6 text-4xl font-extrabold leading-[1.05] tracking-tight text-slate-900 sm:text-5xl lg:text-6xl"
        >
          Levante, organize e
          <span
            class="bg-linear-to-br from-brand-600 to-sky-500 bg-clip-text text-transparent"
            >exporte requisitos</span
          > em minutos.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-600">
          Doclyflow simplifica o processo de criação de documentos de
          requisitos. Capture funcionais e não-funcionais, defina prioridades e
          gere um PDF profissional pronto para enviar ao seu cliente.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <!-- CTA principal: vai direto para /login com `?next=/painel/` em vez
               de /painel. Evita o duplo redirect visível (painel -> login) que
               acontecia via guarda do AppSidebar quando o user estava deslogado.
               O LoginForm já redireciona para o `next` se o user JÁ estiver
               autenticado, então logados caem direto na lista de documentos. -->
          <a
            href="/painel"
            data-cta-auth-gate="/login?next=/painel"
            class="group inline-flex items-center gap-2 rounded-md bg-brand-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700 active:scale-[0.98]"
          >
            Comece agora
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="transition-transform group-hover:translate-x-0.5"
            >
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
          <a
            href="/login?next=/painel/novo"
            class="inline-flex items-center gap-2 rounded-md border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-100"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 48 48"
              aria-hidden="true"
            >
              <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
              <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
              <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/>
              <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
            </svg>
            Entrar com Google
          </a>
        </div>
        <div
          class="mt-10 grid grid-cols-3 gap-6 border-t border-slate-200 pt-6 text-sm text-slate-500"
        >
          <div>
            <div class="text-xl font-bold text-slate-900">Cloud</div>
            <div>Sempre na nuvem</div>
          </div>
          <div>
            <div class="text-xl font-bold text-slate-900">Google</div>
            <div>Login seguro</div>
          </div>
          <div>
            <div class="text-xl font-bold text-slate-900">PDF · MD</div>
            <div>Exporte como quiser</div>
          </div>
        </div>
      </div>

      <!-- mockup preview -->
      <div class="relative">
        <div
          class="absolute -inset-4 -z-10 rounded-3xl bg-linear-to-br from-brand-100/50 to-sky-100/40 blur-2xl"
        >
        </div>
        <div
          class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl"
        >
          <div
            class="flex items-center gap-2 border-b border-slate-200 bg-slate-50/80 px-4 py-3"
          >
            <span class="h-3 w-3 rounded-full bg-red-400"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
            <span class="h-3 w-3 rounded-full bg-green-400"></span>
            <span class="ml-3 text-xs font-medium text-slate-500">
              Projeto - Sistema de E-commerce B2B
            </span>
          </div>
          <div class="space-y-5 p-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <div
                  class="text-xs font-semibold uppercase tracking-wider text-brand-600"
                >
                  Projeto
                </div>
                <div class="mt-1 text-base font-semibold text-slate-900">
                  Sistema de E-commerce B2B
                </div>
                <div class="text-xs text-slate-500">Cliente: Acme Corp</div>
              </div>
              <span
                class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700"
              >
                <CheckCircle2 size={12} /> Concluído
              </span>
            </div>
            <div class="space-y-2 border-t border-dashed border-slate-200 pt-4">
              <div
                class="flex items-start gap-3 rounded-lg border border-slate-100 bg-white p-3 shadow-sm transition hover:shadow-md"
              >
                <span
                  class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md bg-brand-600 text-[10px] font-bold text-white"
                  >F</span
                >
                <div class="flex-1">
                  <div class="text-sm font-medium text-slate-900">
                    Autenticação de usuários via SSO
                  </div>
                  <div class="mt-1 flex flex-wrap gap-1.5 text-[11px]">
                    <span
                      class="rounded bg-orange-100 px-1.5 py-0.5 font-semibold text-orange-700"
                      >Alta</span
                    >
                    <span
                      class="rounded bg-blue-100 px-1.5 py-0.5 font-semibold text-blue-700"
                      >Funcional</span
                    >
                  </div>
                </div>
              </div>
              <div
                class="flex items-start gap-3 rounded-lg border border-slate-100 bg-white p-3 shadow-sm transition hover:shadow-md"
              >
                <span
                  class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md bg-sky-600 text-[10px] font-bold text-white"
                  >N</span
                >
                <div class="flex-1">
                  <div class="text-sm font-medium text-slate-900">
                    Tempo de resposta &lt; 200ms em p95
                  </div>
                  <div class="mt-1 flex flex-wrap gap-1.5 text-[11px]">
                    <span
                      class="rounded bg-red-100 px-1.5 py-0.5 font-semibold text-red-700"
                      >Crítica</span
                    >
                    <span
                      class="rounded bg-violet-100 px-1.5 py-0.5 font-semibold text-violet-700"
                      >Não-funcional</span
                    >
                  </div>
                </div>
              </div>
              <div
                class="flex items-start gap-3 rounded-lg border border-slate-100 bg-white p-3 shadow-sm transition hover:shadow-md"
              >
                <span
                  class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md bg-brand-600 text-[10px] font-bold text-white"
                  >F</span
                >
                <div class="flex-1">
                  <div class="text-sm font-medium text-slate-900">
                    Carrinho persistente entre sessões
                  </div>
                  <div class="mt-1 flex flex-wrap gap-1.5 text-[11px]">
                    <span
                      class="rounded bg-yellow-100 px-1.5 py-0.5 font-semibold text-yellow-700"
                      >Média</span
                    >
                    <span
                      class="rounded bg-blue-100 px-1.5 py-0.5 font-semibold text-blue-700"
                      >Funcional</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES — delegated to <FeaturesGrid /> component -->
  <FeaturesGrid
    features={features}
    title="Tudo que você precisa para um levantamento profissional"
    subtitle="Recursos pensados para analistas, product managers e desenvolvedores que precisam documentar com agilidade."
  />

  <!-- TELAS DO SISTEMA — galeria com as 4 telas reais do produto em grid 2x2.
       Posicionada entre FeaturesGrid e StepsTimeline para o fluxo
       "features → como é o produto → como usar". -->
  <section
    class="relative overflow-hidden border-t border-slate-200 bg-slate-50 py-24"
  >
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <span
          class="inline-flex items-center gap-1.5 rounded-full border border-brand-200 bg-white/80 px-3 py-1 text-xs font-semibold text-brand-700 shadow-sm backdrop-blur"
        >
          <Sparkles size={12} /> Por dentro
        </span>
        <h2
          class="mt-5 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
        >
          Veja o sistema por dentro
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          Conheça o seu novo gestor de levantamentos de requisitos.
        </p>
      </div>

      <div class="mt-16 grid gap-12 lg:grid-cols-2">
        <ScreenCard
          label="Dashboard — lista de documentos"
          dotColor="bg-brand-500"
        >
          <DashboardScreen />
        </ScreenCard>
        <ScreenCard label="Criar documento" dotColor="bg-violet-500">
          <DocumentFormScreen />
        </ScreenCard>
        <ScreenCard
          label="Visualização dos requisitos"
          dotColor="bg-amber-500"
        >
          <RequirementsScreen />
        </ScreenCard>
        <ScreenCard
          label="PDF gerado pronto para enviar"
          dotColor="bg-emerald-500"
        >
          <PdfScreen />
        </ScreenCard>
      </div>
    </div>
  </section>

  <!-- Mesma estratégia do CTA "Comece agora" do hero: href real em
       `/painel/novo` (alvo legítimo) + `data-cta-auth-gate` apontando para
       o caminho `/login?next=...` que o script inline usa quando não há
       sessão. Sem JS, o AppSidebar continua protegendo `/painel/novo`. -->
  <StepsTimeline
    steps={steps}
    badge="Como funciona"
    title="Em três passos você tem seu documento pronto"
    subtitle="Sem curva de aprendizado. Sem complicação."
    cta={{ text: "Começar agora", href: "/painel/novo", authGate: "/login?next=/painel/novo" }}
  />
</Layout>

<!--
  Inline pre-auth para CTAs da landingpage.

  Para qualquer <a> com `data-cta-auth-gate="...", o script intercepta o
  clique e decide o destino FINAL ANTES da navegação começar:

    • logado (token em localStorage)        → segue o href nativo (sem
                                              flicker do /login).
    • deslogado                              → preventDefault + navega para
                                              `data-cta-auth-gate` (sem o
                                              flicker de pisar em /painel).
    • sem JS                                 → segue o href; o guard do
                                              AppSidebar assume e joga o
                                              usuário para /login?next=…

  Por que inline (não módulo): esta página é 100% estática e o handler
  precisa rodar ANTES do browser terminar de montar a ilha React — script
  inline executa na fase de parsing, antes do `DOMContentLoaded` da ilha.
  Com `{ capture: true }` ganhamos prioridade sobre qualquer outro handler
  registrado por React/Astro. Modifier keys (Ctrl/Cmd/Shift/middle-click)
  são preservadas — só interceptamos clicks "puros" do botão esquerdo.

  Mantemos a chave `doclyflow:auth:v1` em sincronia com `storage.ts`. Qualquer
  alteração no schema do storage exige atualizar este script também.
-->
<script is:inline>
  (function () {
    var STORAGE_KEY = 'doclyflow:auth:v1';
    function isAuthed() {
      try {
        return !!window.localStorage.getItem(STORAGE_KEY);
      } catch (_) {
        return false;
      }
    }
    document.addEventListener(
      'click',
      function (e) {
        // Pula clicks com modifier — o usuário pediu "abrir em nova aba".
        if (e.ctrlKey || e.metaKey || e.shiftKey || e.altKey || e.button !== 0) {
          return;
        }
        var a = e.target && e.target.closest
          ? e.target.closest('a[data-cta-auth-gate]')
          : null;
        if (!a) return;
        if (isAuthed()) return; // logado: usa /painel direto, sem flicker
        // Defensive: se algum `<a>` chegar sem `data-cta-auth-gate` definido
        // (atributo ausente OU string vazia), abortamos e deixamos a
        // navegação seguir o href nativo — evita `window.location.href = ''`.
        var gate = a.getAttribute('data-cta-auth-gate');
        if (!gate) return;
        e.preventDefault();
        window.location.href = gate;
      },
      { capture: true },
    );
  })();
</script>
