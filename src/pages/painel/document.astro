---
import Layout from '../../layouts/Layout.astro';
import DocumentView from '../../react/DocumentView.tsx';
import AppSidebar from '../../react/AppSidebar.tsx';

// Rota 100% estática — o ID do documento é resolvido pelo `DocumentView`
// a partir de `?id=<uuid>` (com fallback de path para back-compat).
// SEO é irrelevante aqui (toda a área é autenticada) e todo o roteamento
// dinâmico passa para o React, mantendo o build como cliente estático.
---

<Layout title="Documento · Doclify" hideChrome>
  <div class="min-h-screen">
    <AppSidebar client:only="react" activeRoute="documents" />
    <main class="min-w-0 lg:pl-65">
      <div class="mx-auto max-w-360 px-4 pt-20 pb-8 sm:px-6 sm:pt-24 sm:pb-10 lg:pt-10">
        <DocumentView client:load />
      </div>
    </main>
  </div>
</Layout>
