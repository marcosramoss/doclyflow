# =============================================================================
# Doclyflow API — environment template
# =============================================================================
# Copie para api/.env e ajuste os valores:
#   cp api/.env.example api/.env        (Linux/macOS)
#   copy api/.env.example api\.env      (Windows)
# =============================================================================

# --- CORS --------------------------------------------------------------------
# Origem permitida para o frontend durante o desenvolvimento.
# Em produção, troque pela URL definitiva (ex.: https://app.exemplo.com).
FRONTEND_ORIGIN=http://localhost:4321

# --- MySQL -------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=doclyflow
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- Auth --------------------------------------------------------------------
# Tempo de vida dos tokens em horas (default: 7 dias).
TOKEN_TTL_HOURS=168

# Google OAuth (Google Identity Services + ID token flow).
# - GOOGLE_CLIENT_ID também é usado no frontend (variável `PUBLIC_GOOGLE_CLIENT_ID`
#   em `.env` na raiz do projeto Astro, ou hardcoded em `src/react/LoginForm.tsx`).
# - Em produção, cadastre os origins permitidos em
#   https://console.cloud.google.com/apis/credentials (Web client).
#
# Os valores abaixo são placeholders SEGUROS — os tokens reais ficam em
# `api/.env` (gitignored). Para popular com seu próprio client OAuth Web
# (criado no GCP Console), basta substituir nos próprios valores:
#
#   GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
#   GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
