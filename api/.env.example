# =============================================================================
# Doclify API — environment template
# =============================================================================
# Copie para api/.env e ajuste os valores:
#   cp api/.env.example api/.env        (Linux/macOS)
#   copy api/.env.example api\.env      (Windows)
# =============================================================================

# --- CORS --------------------------------------------------------------------
# Origem permitida para o frontend durante o desenvolvimento.
# Em produção, troque pela URL definitiva (ex.: https://app.exemplo.com).
FRONTEND_ORIGIN=http://localhost:4321

# --- MySQL -------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=doclify
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- Auth --------------------------------------------------------------------
# Tempo de vida dos tokens em horas (default: 7 dias).
TOKEN_TTL_HOURS=168

# Auto-registro no login (comportamento equivalente ao mock do frontend).
# Em produção, defina `false` para exigir cadastro prévio e fechar o vetor
# de user-enumeration via timing.
AUTH_AUTO_REGISTER=true
