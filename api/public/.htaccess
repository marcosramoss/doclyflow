# =============================================================================
# Doclyflow API — Apache config.
# =============================================================================
# Habilita o servidor Apache (com mod_rewrite) a rotear requisições
# desconhecidas para o front controller em api/public/index.php.
#
# Não é necessário se for usar exclusivamente o `php -S` embutido.
# =============================================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Permite que reqisições a diretórios sirvam os arquivos reais (sem /index.php).
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Tudo o mais vai para o front controller.
    RewriteRule ^ index.php [L]
</IfModule>

# Bloqueia acesso direto a arquivos sensíveis dentro de api/ via tentativa
# de bypass do RewriteRule.
<FilesMatch "^(\.\.|\.env|\.git)">
    Require all denied
</FilesMatch>
